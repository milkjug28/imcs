# Supabase (SERVER-SIDE ONLY - NOT NEXT_PUBLIC_)
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci... (your service role key - keep this SECRET!)

# WalletConnect (CLIENT-SIDE - safe to expose)
# Get this from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# Google Sheets (OPTIONAL - backup submission storage)
# Keep your existing Google Apps Script URL if you have one
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# Admin Secret (for syncing Google Sheets to Supabase)
# Generate a random secret: openssl rand -hex 32
ADMIN_SECRET_KEY=your-secret-key-here

# Admin Password (SERVER-SIDE ONLY - never use NEXT_PUBLIC_ for passwords!)
ADMIN_PASSWORD=your-secure-password-here

# Discord Bot & OAuth
# Create app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-app-client-id
NEXT_PUBLIC_URL=https://imcs.world

# Discord Server Config
# Enable Developer Mode in Discord > right-click to copy IDs
DISCORD_GUILD_ID=your-discord-server-id
DISCORD_VERIFICATION_CHANNEL_ID=your-verification-channel-id
DISCORD_ROLE_VERIFIED=role-id-for-verified
DISCORD_ROLE_REEL_SABANT=role-id-for-reel-sabant
DISCORD_ROLE_SUPA_SAVANAT=role-id-for-supa-savanat
DISCORD_ROLE_CHED_SAVANT=role-id-for-ched-savant

# Alchemy (already exists - used for NFT verification)
ALCHEMY_API_KEY=your-alchemy-api-key
